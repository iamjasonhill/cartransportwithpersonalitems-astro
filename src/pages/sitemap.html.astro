---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';

const basePages = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services' },
  { href: '/services/core-service/', label: 'Core Service' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];
const trustPages = Array.isArray(site.trustLinks) ? site.trustLinks : [];
const pages = [...basePages, ...trustPages].filter(
  (page, index, collection) => collection.findIndex((candidate) => candidate.href === page.href) === index,
);
---
<BaseLayout
  title={`${site.name} HTML Sitemap`}
  description={`HTML sitemap for ${site.name}.`}
  canonicalPath="/sitemap.html"
  breadcrumbs={[
    { name: 'Home', url: site.url },
    { name: 'HTML Sitemap', url: `${site.url.replace(/\/$/, '')}/sitemap.html` },
  ]}
>
  <h1>{site.name} HTML Sitemap</h1>
  <ul>
    {pages.map((page) => (
      <li><a href={page.href}>{page.label}</a></li>
    ))}
  </ul>
</BaseLayout>
