---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';

const title = `${site.name} Service Overview`;
const description = `This legacy route now points to the main services page for ${site.name}.`;
const breadcrumbs = [
  { name: 'Home', url: site.url },
  { name: 'Services', url: new URL('/services/', site.url).toString() },
  { name: 'Service Overview', url: new URL('/services/core-service/', site.url).toString() },
];
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath="/services/"
  breadcrumbs={breadcrumbs}
  noindex={true}
>
  <h1>Service Overview</h1>
  <p>This legacy page is kept so older links still resolve, but the maintained service information now lives on the main Services page.</p>
  <p><a href="/services/">Go to Services</a></p>
</BaseLayout>
