---
import { design } from '../lib/design';
import { site } from '../lib/site';
import '../styles/theme.css';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  breadcrumbs?: BreadcrumbItem[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  breadcrumbs = [],
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, Astro.site ?? site.url).toString();
const socialImageUrl = new URL(site.seoAssets.ogImage, Astro.site ?? site.url).toString();
const twitterImageUrl = new URL(site.seoAssets.twitterImage, Astro.site ?? site.url).toString();
const faviconType = site.seoAssets.favicon.endsWith('.png') ? 'image/png' : 'image/svg+xml';
const fontStylesheets = (() => {
  const primaryFontUrl = typeof design.typography?.fontUrl === 'string' ? design.typography.fontUrl.trim() : '';
  if (primaryFontUrl !== '') {
    return [primaryFontUrl];
  }

  return Array.from(new Set(Array.isArray(design.typography?.fontUrls) ? design.typography.fontUrls : []));
})();
const themeFamily = typeof design.theme?.family === 'string' ? design.theme.family : 'service_classic';
const isAuvergneFamily = themeFamily === 'auvergne_authority';
const isEditorialFamily = themeFamily === 'editorial_authority';
const isConversionFamily = themeFamily === 'modern_conversion';
const isCorporateFamily = themeFamily === 'corporate_command';
const primaryCtaHref = site.navigation.find((item) => item.href.includes('contact'))?.href ?? '/contact/';
const primaryNavItems = site.navigation.slice(0, 4);
const footerNavItems = site.navigation.slice(0, 4);
const footerTrustItems = [...site.trustLinks, { href: '/sitemap.html', label: 'HTML Sitemap' }];
const themeStyle = [
  `--de-color-background: ${design.palette.background}`,
  `--de-color-surface: ${design.palette.surface}`,
  `--de-color-text: ${design.palette.text}`,
  `--de-color-muted: ${design.palette.muted}`,
  `--de-color-border: ${design.palette.border}`,
  `--de-color-primary: ${design.palette.primary}`,
  `--de-color-secondary: ${design.palette.secondary}`,
  `--de-color-accent: ${design.palette.accent}`,
  `--de-font-heading: ${design.typography.headingStack}`,
  `--de-font-body: ${design.typography.bodyStack}`,
  `--de-radius: ${design.shape.radius}`,
  `--de-shadow: ${design.shape.shadow}`,
  `--de-content-width: ${design.layout.contentWidth}`,
  `--de-section-gap: ${design.layout.sectionGap}`,
  `--de-button-radius: ${design.ctaStyle === 'pill' ? '999px' : design.shape.radius}`,
  `--de-pattern-background: url('${design.assets.patternBackground}')`,
].join('; ');
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
};
const breadcrumbSchema = breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.name,
        item: item.url,
      })),
    }
  : null;
---
<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex,follow' : 'index,follow'} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={site.locale.replace('-', '_')} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={`${site.name} social share image`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={twitterImageUrl} />
    <link rel="icon" type={faviconType} href={site.seoAssets.favicon} />
    <link rel="apple-touch-icon" sizes="180x180" href={site.seoAssets.appleTouchIcon} />
    <link rel="canonical" href={canonicalUrl} />
    {fontStylesheets.length > 0 && <link rel="preconnect" href="https://fonts.googleapis.com" />}
    {fontStylesheets.length > 0 && <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />}
    {fontStylesheets.map((fontUrl) => <link rel="stylesheet" href={fontUrl} />)}
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  </head>
  <body class:list={['site-shell', `theme-${design.theme.family}`, `density-${design.density}`, `cta-${design.ctaStyle}`]} style={themeStyle}>
    <div class="site-frame">
      <header class:list={['site-header', `site-header-${themeFamily}`]}>
        <div class="site-container">
          {isEditorialFamily ? (
            <div class="site-header-inner site-header-inner-editorial">
              <div class="site-header-brand-block">
                <a class="site-brand" href="/">
                  <span class="site-brand-mark">
                    <img src={design.assets.logo} alt={`${site.name} logo`} width="44" height="44" />
                  </span>
                  <span class="site-brand-copy">
                    <span class="site-brand-name">{site.name}</span>
                  </span>
                </a>
              </div>
              <div class="site-header-actions site-header-actions-editorial">
                <nav class="site-nav" aria-label="Primary">
                  {primaryNavItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
              </div>
            </div>
          ) : isAuvergneFamily ? (
            <div class="site-header-inner site-header-inner-auvergne">
              <a class="site-brand" href="/">
                <span class="site-brand-mark">
                  <img src={design.assets.logo} alt={`${site.name} logo`} width="44" height="44" />
                </span>
                <span class="site-brand-copy">
                  <span class="site-brand-name">{site.name}</span>
                </span>
              </a>
              <div class="site-header-actions site-header-actions-auvergne">
                <nav class="site-nav" aria-label="Primary">
                  {primaryNavItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
                <a class="site-header-cta" href={primaryCtaHref}>Get In Touch</a>
              </div>
            </div>
          ) : isCorporateFamily ? (
            <div class="site-header-inner site-header-inner-corporate">
              <div class="site-header-brand-block">
                <a class="site-brand" href="/">
                  <span class="site-brand-mark">
                    <img src={design.assets.logo} alt={`${site.name} logo`} width="44" height="44" />
                  </span>
                  <span class="site-brand-copy">
                    <span class="site-brand-name">{site.name}</span>
                  </span>
                </a>
              </div>
              <div class="site-header-actions site-header-actions-corporate">
                <nav class="site-nav" aria-label="Primary">
                  {primaryNavItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
                <a class="site-header-cta" href={primaryCtaHref}>Request A Quote</a>
              </div>
            </div>
          ) : isConversionFamily ? (
            <div class="site-header-inner site-header-inner-conversion">
              <a class="site-brand" href="/">
                <span class="site-brand-mark">
                  <img src={design.assets.logo} alt={`${site.name} logo`} width="44" height="44" />
                </span>
                <span class="site-brand-copy">
                  <span class="site-brand-name">{site.name}</span>
                </span>
              </a>
              <div class="site-header-actions site-header-actions-conversion">
                <nav class="site-nav" aria-label="Primary">
                  {primaryNavItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
                <a class="site-header-cta" href={primaryCtaHref}>Start With A Quote</a>
              </div>
            </div>
          ) : (
            <div class="site-header-inner site-header-inner-classic">
              <div class="site-header-brand-block">
                <a class="site-brand" href="/">
                  <span class="site-brand-mark">
                    <img src={design.assets.logo} alt={`${site.name} logo`} width="44" height="44" />
                  </span>
                  <span class="site-brand-copy">
                    <span class="site-brand-name">{site.name}</span>
                  </span>
                </a>
              </div>
              <nav class="site-nav" aria-label="Primary">
                {primaryNavItems.map((item) => (
                  <a href={item.href}>{item.label}</a>
                ))}
              </nav>
            </div>
          )}
        </div>
      </header>
      <main class="site-main">
        <div class="site-container">
          <slot />
        </div>
      </main>
      <footer class:list={['site-footer', `site-footer-${themeFamily}`]}>
        <div class="site-container">
          {isEditorialFamily ? (
            <div class="site-footer-inner site-footer-inner-editorial">
              <div class="site-footer-column site-footer-column-brand">
                <span class="site-brand-name">{site.name}</span>
              </div>
              <div class="site-footer-column">
                <span class="site-footer-label">Explore</span>
                <nav class="site-footer-link-list" aria-label="Footer explore">
                  {footerNavItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
              </div>
              <div class="site-footer-column">
                <span class="site-footer-label">Trust & Discovery</span>
                <nav class="site-footer-link-list" aria-label="Footer trust">
                  {footerTrustItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
              </div>
            </div>
          ) : isAuvergneFamily ? (
            <div class="site-footer-inner site-footer-inner-auvergne">
              <div class="site-footer-column site-footer-column-brand">
                <span class="site-brand-name">{site.name}</span>
              </div>
              <div class="site-footer-column">
                <span class="site-footer-label">Navigate</span>
                <nav class="site-footer-link-list" aria-label="Footer navigation">
                  {footerNavItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
              </div>
              <div class="site-footer-column">
                <span class="site-footer-label">Trust & Discovery</span>
                <nav class="site-footer-link-list" aria-label="Footer trust">
                  {footerTrustItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
              </div>
              <div class="site-footer-column site-footer-column-meta">
                <span class="site-footer-label">All rights reserved</span>
                <p class="site-footer-note">&copy; <span data-current-year></span> {site.name}</p>
              </div>
            </div>
          ) : isCorporateFamily ? (
            <div class="site-footer-inner site-footer-inner-corporate">
              <div class="site-footer-column site-footer-column-brand">
                <span class="site-brand-name">{site.name}</span>
              </div>
              <div class="site-footer-column">
                <span class="site-footer-label">Capabilities</span>
                <nav class="site-footer-link-list" aria-label="Footer capabilities">
                  {footerNavItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
              </div>
              <div class="site-footer-column">
                <span class="site-footer-label">Trust & Discovery</span>
                <nav class="site-footer-link-list" aria-label="Footer trust">
                  {footerTrustItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
              </div>
            </div>
          ) : isConversionFamily ? (
            <div class="site-footer-stack site-footer-stack-conversion">
              <div class="site-footer-promo site-footer-promo-conversion">
                <a class="site-footer-cta" href={primaryCtaHref}>Request A Quote</a>
              </div>
              <div class="site-footer-inner site-footer-inner-conversion">
                <div class="site-footer-column site-footer-column-brand">
                  <span class="site-brand-name">{site.name}</span>
                </div>
                <div class="site-footer-column">
                  <span class="site-footer-label">Explore</span>
                  <nav class="site-footer-link-list" aria-label="Footer explore">
                    {footerNavItems.map((item) => (
                      <a href={item.href}>{item.label}</a>
                    ))}
                  </nav>
                </div>
                <div class="site-footer-column">
                  <span class="site-footer-label">Trust</span>
                  <nav class="site-footer-link-list" aria-label="Footer trust">
                    {footerTrustItems.map((item) => (
                      <a href={item.href}>{item.label}</a>
                    ))}
                  </nav>
                </div>
              </div>
            </div>
          ) : (
            <div class="site-footer-inner site-footer-inner-classic">
              <div class="site-footer-column site-footer-column-brand">
                <span class="site-brand-name">{site.name}</span>
              </div>
              <div class="site-footer-column">
                <span class="site-footer-label">Company</span>
                <nav class="site-footer-link-list" aria-label="Footer company">
                  {footerNavItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
              </div>
              <div class="site-footer-column">
                <span class="site-footer-label">Trust</span>
                <nav class="site-footer-link-list" aria-label="Footer trust">
                  {footerTrustItems.map((item) => (
                    <a href={item.href}>{item.label}</a>
                  ))}
                </nav>
              </div>
            </div>
          )}
        </div>
      </footer>
    </div>
    <script>
      document.querySelectorAll('[data-current-year]').forEach((node) => {
        node.textContent = String(new Date().getFullYear());
      });
    </script>
  </body>
</html>
