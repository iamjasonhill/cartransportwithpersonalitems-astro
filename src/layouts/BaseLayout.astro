---
import BrandLayout from './BrandLayout.astro';

const { title, description, canonicalPath, breadcrumbs, noindex } = Astro.props;
---
<BrandLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  breadcrumbs={breadcrumbs}
  noindex={noindex}
>
  <section class="page-band">
    <div class="section-inner page-prose">
      <slot />
    </div>
  </section>
</BrandLayout>
