---
import { design } from '../lib/design';
import { site } from '../lib/site';
import '../styles/theme.css';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  breadcrumbs?: BreadcrumbItem[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  breadcrumbs = [],
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, Astro.site ?? site.url).toString();
const socialImageUrl = new URL(site.seoAssets.ogImage, Astro.site ?? site.url).toString();
const twitterImageUrl = new URL(site.seoAssets.twitterImage, Astro.site ?? site.url).toString();
const faviconType = site.seoAssets.favicon.endsWith('.png') ? 'image/png' : 'image/svg+xml';
const fontUrls = Array.from(new Set(Array.isArray(design.typography?.fontUrls) ? design.typography.fontUrls : []));
const themeStyle = [
  `--de-color-background: ${design.palette.background}`,
  `--de-color-surface: ${design.palette.surface}`,
  `--de-color-text: ${design.palette.text}`,
  `--de-color-muted: ${design.palette.muted}`,
  `--de-color-border: ${design.palette.border}`,
  `--de-color-primary: ${design.palette.primary}`,
  `--de-color-secondary: ${design.palette.secondary}`,
  `--de-color-accent: ${design.palette.accent}`,
  `--de-font-heading: ${design.typography.headingStack}`,
  `--de-font-body: ${design.typography.bodyStack}`,
  `--de-radius: ${design.shape.radius}`,
  `--de-shadow: ${design.shape.shadow}`,
  `--de-content-width: ${design.layout.contentWidth}`,
  `--de-section-gap: ${design.layout.sectionGap}`,
  `--de-button-radius: ${design.ctaStyle === 'pill' ? '999px' : design.shape.radius}`,
  `--de-pattern-background: url('${design.assets.patternBackground}')`,
].join('; ');
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.url,
};
const breadcrumbSchema = breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.name,
        item: item.url,
      })),
    }
  : null;
---
<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex,follow' : 'index,follow'} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={site.locale.replace('-', '_')} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={`${site.name} social share image`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={twitterImageUrl} />
    <link rel="icon" type={faviconType} href={site.seoAssets.favicon} />
    <link rel="apple-touch-icon" sizes="180x180" href={site.seoAssets.appleTouchIcon} />
    <link rel="canonical" href={canonicalUrl} />
    {fontUrls.length > 0 && <link rel="preconnect" href="https://fonts.googleapis.com" />}
    {fontUrls.length > 0 && <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />}
    {fontUrls.map((fontUrl) => <link rel="stylesheet" href={fontUrl} />)}
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  </head>
  <body class:list={['site-shell', `theme-${design.theme.family}`, `density-${design.density}`, `cta-${design.ctaStyle}`]} style={themeStyle}>
    <div class="site-frame">
      <header class="site-header">
        <div class="site-container">
          <div class="site-header-inner">
            <a class="site-brand" href="/">
              <span class="site-brand-mark">
                <img src={design.assets.logo} alt={`${site.name} logo`} width="44" height="44" />
              </span>
              <span class="site-brand-copy">
                <span class="site-brand-kicker">Deftly Site System</span>
                <span class="site-brand-name">{site.name}</span>
              </span>
            </a>
            <nav class="site-nav" aria-label="Primary">
              {site.navigation.map((item) => (
                <a href={item.href}>{item.label}</a>
              ))}
            </nav>
          </div>
        </div>
      </header>
      <main class="site-main">
        <div class="site-container">
          <slot />
        </div>
      </main>
      <footer class="site-footer">
        <div class="site-container">
          <div class="site-footer-inner">
            <div class="site-brand-copy">
              <span class="site-brand-name">{site.name}</span>
              <span class="site-footer-note">Structured content, strong technical SEO, and a synced visual system.</span>
            </div>
            <nav class="site-footer-nav" aria-label="Footer">
              {site.trustLinks.map((item) => (
                <a href={item.href}>{item.label}</a>
              ))}
              <a href="/sitemap.html">HTML Sitemap</a>
            </nav>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
