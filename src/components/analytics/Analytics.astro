---
import Ga4 from './Ga4.astro';
import Matomo from './Matomo.astro';
import { site } from '../../lib/site';

function cleanEnv(value) {
  return typeof value === 'string' ? value.trim() : '';
}

function parseJsonRecord(value) {
  if (!value) return null;
  try {
    const parsed = JSON.parse(value);
    if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;
    return Object.fromEntries(
      Object.entries(parsed).map(([key, item]) => [
        key,
        item == null ? '' : typeof item === 'string' ? item.trim() : String(item),
      ])
    );
  } catch {
    return null;
  }
}

const analyticsEnabled = cleanEnv(import.meta.env.PUBLIC_ANALYTICS_ENABLED);
const analyticsProvider = cleanEnv(import.meta.env.PUBLIC_ANALYTICS_PROVIDER);
const analyticsConfig = parseJsonRecord(cleanEnv(import.meta.env.PUBLIC_ANALYTICS_CONFIG));
const gaMeasurementId = cleanEnv(import.meta.env.PUBLIC_GA_MEASUREMENT_ID) || 'G-57FRYPX9DB';
const gaTagUrl = cleanEnv(import.meta.env.PUBLIC_GA_TAG_URL) || 'https://www.googletagmanager.com/gtag/js';
const gaSendPageView = cleanEnv(import.meta.env.PUBLIC_GA_SEND_PAGE_VIEW) || 'true';
const gaAnonymizeIp = cleanEnv(import.meta.env.PUBLIC_GA_ANONYMIZE_IP) || 'false';

let provider = null;
let config = {};

if (analyticsProvider && analyticsConfig) {
  provider = analyticsProvider;
  config = analyticsConfig;
} else if (gaMeasurementId) {
  provider = 'ga4';
  config = {
    measurement_id: gaMeasurementId,
    tag_url: gaTagUrl,
    send_page_view: gaSendPageView,
    anonymize_ip: gaAnonymizeIp,
    site_key: site.analytics.siteKey,
  };
} else if (import.meta.env.PUBLIC_MATOMO_BASE_URL && import.meta.env.PUBLIC_MATOMO_SITE_ID) {
  provider = 'matomo';
  config = {
    base_url: import.meta.env.PUBLIC_MATOMO_BASE_URL,
    site_id: import.meta.env.PUBLIC_MATOMO_SITE_ID,
  };
}

const enabled = analyticsEnabled ? analyticsEnabled.toLowerCase() === 'true' : Boolean(provider);
---

{import.meta.env.PROD && enabled && provider === 'ga4' && (
  <Ga4
    measurementId={config.measurement_id}
    tagUrl={config.tag_url}
    sendPageView={config.send_page_view}
    anonymizeIp={config.anonymize_ip}
    siteKey={config.site_key || site.analytics.siteKey}
    trackedLinks={site.analytics.trackedLinks}
  />
)}
{import.meta.env.PROD && enabled && provider === 'matomo' && <Matomo />}
